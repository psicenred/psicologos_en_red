# =============================================================================
# Psicólogos en Red — variables de entorno (sandbox / Next.js)
# Copiar a .env y completar. Nunca commitear .env
# Generar SESSION_SECRET: openssl rand -hex 32
# =============================================================================

# ── App / sitio ──────────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000
PUBLIC_URL=http://localhost:3000
NODE_ENV=development

# ── Sesión (URGENTE: reemplaza secret hardcodeado legacy en producción) ───────
SESSION_SECRET=

# ── Puertos (desarrollo: Next 3000, Express legacy 3001) ───────────────────────
PORT=3000
LEGACY_PORT=3001

# ── Supabase (Postgres + Storage; NO usar Supabase Auth) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Connection string Postgres (Supabase → Settings → Database → URI, modo pooler)
DATABASE_URL=

# Aliases legacy Railway (opcional)
# DATABASE_PUBLIC_URL=
# DATABASE_PRIVATE_URL=
# POSTGRES_URL=

# ── Stripe Connect ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Prueba cobro mínimo: descomentar para cobrar 1 MXN en sandbox
# STRIPE_TEST_AMOUNT_MXN=1
# Webhook local: stripe listen --forward-to localhost:3000/api/webhook/stripe

# ── Email (Resend — preferido) ─────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=contacto@psicologosenred.com

# ── Email (Nodemailer / Zoho — fallback) ───────────────────────────────────────
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# ── WhatsApp (Twilio) ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_FROM=+525530776194

# ── Videollamadas (Daily.co) ───────────────────────────────────────────────────
DAILY_API_KEY=

# ── Jitsi legacy (fallback, opcional) ──────────────────────────────────────────
JAAS_APP_ID=
JAAS_KID=
JAAS_PRIVATE_KEY=

# ── Cifrado mensajes de chat y notas clínicas (AES-256-GCM) ─────────────────
# Generar: openssl rand -hex 32
MENSAJES_ENCRYPTION_KEY=

# ── Chatbot (Groq) ─────────────────────────────────────────────────────────────
GROQ_API_KEY=
CHAT_WHATSAPP_NUMBER=5215530776194

# ── Crons externos (cron-job.org) ──────────────────────────────────────────────
# Header: x-cron-secret: <valor>
CRON_SECRET=
